NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=
SHOPIFY_STOREFRONT_API_TOKEN=

# Public site URL — used for metadataBase, canonical/hreflang URLs, and the
# sitemap/robots routes (see lib/seo.ts). No production domain is confirmed
# yet (openspec/changes/mvp-launch/proposal.md open dependency); the app
# falls back to http://localhost:3000 when unset. Set to the real
# production URL (with protocol, no trailing slash) once the domain lands —
# every canonical/OG/sitemap URL derives from this one var, nothing else to
# change.
NEXT_PUBLIC_SITE_URL=

# Commerce backend selector: "sanity" (default — live catalog) or "fixtures"
# (no credentials required; dev/test-only override, e.g. COMMERCE_SOURCE=fixtures).
COMMERCE_SOURCE=

# Sanity project — public (non-secret) identifiers. The real values have a
# documented fallback default in sanity/env.ts, so these can stay blank here.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=

# Only required if the Sanity dataset is private; this project's dataset is
# public read-only, so leave unset.
# SANITY_READ_TOKEN=

# Server-only write access for the contact form (lib/contact/submit.ts
# writes contactMessage documents). Needs Editor/Create permissions on the
# dataset — a different token than SANITY_READ_TOKEN above. Never prefix
# NEXT_PUBLIC_; the app fails safe (returns a generic error, never throws,
# never logs the token) when this is unset — see lib/contact/write-client.ts.
SANITY_WRITE_TOKEN=

# Stripe Checkout (Day 4) — test-mode keys unblock all development at $0.
# Never commit real (live) values. STRIPE_SECRET_KEY must never be prefixed
# NEXT_PUBLIC_ (that prefix ships the value into the browser bundle); the
# app fails safe (never throws, never logs the key) when it's unset — see
# lib/commerce/stripe/client.ts.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
